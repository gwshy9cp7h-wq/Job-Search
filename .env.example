# Microsoft Graph API (create an Azure App Registration at portal.azure.com)
# See README for step-by-step setup
AZURE_CLIENT_ID=your_azure_app_client_id
AZURE_TENANT_ID=consumers  # use "consumers" for personal @outlook.com/@hotmail.com accounts

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Job Search Preferences (comma-separated keywords)
JOB_KEYWORDS=software engineer,backend developer,python developer
JOB_LOCATION=Remote
JOB_DAYS_BACK=7

# Email Agent
EMAIL_DAYS_BACK=3

# Digest email (leave blank to skip sending digest)
DIGEST_TO_EMAIL=your@email.com
